{
  "name": "poldixd/laravel-matomo-ai-bot-tracking",
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "Nils Poltmann",
      "email": "dev@nils.li"
    }
  ],
  "homepage": "https://github.com/poldixd/laravel-matomo-ai-bot-tracking",
  "require": {
    "php": "^8.2",
    "illuminate/support": "^11.0 || ^12.0 || ^13.0"
  },
  "require-dev": {
    "laravel/pint": "^1.19",
    "orchestra/testbench": "^9.0 || ^10.0 || ^11.0",
    "pestphp/pest": "^3.0 || ^4.0",
    "pestphp/pest-plugin-laravel": "^3.0 || ^4.0"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "poldixd\\MatomoAIBotTracking\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "poldixd\\MatomoAIBotTracking\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "poldixd\\MatomoAIBotTracking\\MatomoAIBotTrackingServiceProvider"
      ]
    }
  },
  "scripts": {
    "test": "vendor/bin/pest"
  }
}
